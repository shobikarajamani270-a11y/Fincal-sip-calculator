{#
  Template: sip-calculator.html.twig
  HDFC Mutual Fund — SIP Calculator Drupal Template
  Compatible: Drupal 10.5.6 | PHP 8.1
#}
<div class="sip-calculator-wrapper" role="main">
  <div class="sip-calculator-header">
    <h1>{{ title }}</h1>
    <p class="sip-subtitle">
      {{ 'Investor Education & Awareness Initiative'|t }}
    </p>
  </div>

  {# Embed Next.js Calculator via iframe #}
  <div class="sip-calculator-embed">
    <iframe
      src="{{ calculator_url }}"
      title="{{ 'HDFC Mutual Fund Goal-Based SIP Calculator'|t }}"
      width="100%"
      height="900"
      frameborder="0"
      loading="lazy"
      allow="same-origin"
      aria-label="{{ 'Interactive SIP Calculator'|t }}"
    ></iframe>
  </div>

  {# Mandatory HDFC Disclaimer #}
  <div class="sip-disclaimer" role="note">
    <strong>{{ 'Disclaimer'|t }}:</strong>
    {{ 'This tool has been designed for information purposes only. Actual results may vary depending on various factors involved in capital market. Investor should not consider above as a recommendation for any schemes of HDFC Mutual Fund. Past performance may or may not be sustained in future and is not a guarantee of any future returns.'|t }}
  </div>
</div>

<style>
.sip-calculator-wrapper {
  font-family: 'Montserrat', Arial, Verdana, sans-serif;
  max-width: 1280px;
  margin: 0 auto;
  padding: 1.5rem;
}
.sip-calculator-header {
  background: #224c87;
  color: #fff;
  padding: 1.5rem 2rem;
  border-radius: 8px;
  margin-bottom: 1.5rem;
}
.sip-calculator-header h1 {
  margin: 0 0 .25rem;
  font-size: 1.5rem;
  font-weight: 700;
}
.sip-subtitle {
  margin: 0;
  font-size: .85rem;
  opacity: .8;
}
.sip-calculator-embed {
  border: 1px solid #d0daea;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 1.5rem;
}
.sip-disclaimer {
  background: #fff8e1;
  border: 1.5px solid #f0c040;
  border-radius: 8px;
  padding: 1rem 1.25rem;
  font-size: .78rem;
  color: #5a4000;
  line-height: 1.75;
}
</style>